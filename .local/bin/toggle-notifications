#!/bin/bash
# Toggle swaync + sync sidebar state
# SIGUSR1 = hide, SIGUSR2 = show (configured in sidebar.jsonc)

sidebar_pid() {
    for pid in $(pgrep waybar); do
        if grep -qz "\-b" /proc/$pid/cmdline 2>/dev/null; then
            echo "$pid"
            return
        fi
    done
}

pid=$(sidebar_pid)
notify_open=$(swaync-client -D 2>/dev/null | grep -c '"visible": true')
FLAG="/tmp/sidebar-hidden-by-notify"

if [ "$notify_open" = "1" ]; then
    # Notify ouvert → fermer + restore sidebar
    swaync-client -t -sw
    [ -n "$pid" ] && kill -SIGUSR2 "$pid" 2>/dev/null
    rm -f "$FLAG"
elif [ -f "$FLAG" ]; then
    # Notify fermé (Escape) mais sidebar encore cachée → juste restore sidebar
    [ -n "$pid" ] && kill -SIGUSR2 "$pid" 2>/dev/null
    rm -f "$FLAG"
else
    # Tout normal → cacher sidebar + ouvrir notify
    [ -n "$pid" ] && kill -SIGUSR1 "$pid" 2>/dev/null
    sleep 0.15
    swaync-client -t -sw
    touch "$FLAG"
fi
